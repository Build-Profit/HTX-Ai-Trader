# Backend API proxy prefix (must match vite.config.ts proxy rule)
VITE_HB_PROXY_PREFIX=/hbapi

# Backend API target URL (used by Vite dev server proxy)
VITE_HB_API_TARGET=http://120.24.229.171:8000

# Hummingbot API Basic Auth (defaults for loadHbAuth; user can override in Settings UI)
VITE_HB_API_USER=htxbot
VITE_HB_API_PASSWORD=hummingbot

# ProfitPrince backend target (HTX live market data, strategy parse, etc.)
VITE_PP_API_TARGET=http://localhost:8000
